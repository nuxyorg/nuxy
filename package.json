{
  "name": "nuxy",
  "version": "2.0.0",
  "private": true,
  "description": "",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm -C src dev",
    "build": "pnpm -C src build",
    "package": "pnpm -C src dist",
    "test": "pnpm -C src test",
    "test:e2e": "pnpm -C src test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^5.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
