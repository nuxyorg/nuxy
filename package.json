{
  "name": "nuxy",
  "version": "2.1.0",
  "private": true,
  "description": "",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "node scripts/dev.mjs",
    "build": "pnpm -C extensions/ui-default build && pnpm -C src build",
    "package": "pnpm -C src dist",
    "test": "pnpm -C src test",
    "test:e2e": "pnpm -C src test:e2e",
    "test:e2e:extensions": "pnpm -C src test:e2e:all",
    "test:e2e:core": "pnpm -C src test:e2e:core",
    "format": "prettier --check .",
    "format:fix": "node scripts/format-fix.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-ext": "node scripts/lint-ext.mjs",
    "typecheck": "pnpm -C src typecheck && tsc --project extensions/tsconfig.json --noEmit",
    "spellcheck": "cspell lint \"**/*.{js,ts,tsx,jsx,json,md,html,css,yml,yaml}\" --no-progress",
    "check": "pnpm format && pnpm lint && pnpm typecheck && pnpm spellcheck",
    "check:fix": "pnpm format:fix && pnpm lint:fix && pnpm typecheck && pnpm spellcheck",
    "deadcode": "knip",
    "create-ext": "node scripts/create-ext.mjs",
    "dev-ext": "node scripts/dev-ext.mjs",
    "doctor": "node scripts/doctor.mjs",
    "docs:dev": "pnpm -C website dev",
    "docs:build": "pnpm -C website build",
    "publish:dry": "node scripts/publish.mjs",
    "publish:all": "node scripts/publish.mjs --publish",
    "publish:patch": "node scripts/publish.mjs --publish patch",
    "publish:minor": "node scripts/publish.mjs --publish minor",
    "publish:npm": "node scripts/publish-npm.mjs --channel stable --publish",
    "publish:npm:dry": "node scripts/publish-npm.mjs --channel stable"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "cspell": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.6.0",
    "knip": "^6.15.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.60.1"
  }
}
