{
  "name": "nuxy",
  "version": "2.0.0",
  "private": true,
  "description": "",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --parallel --filter nuxy-desktop --filter @nuxy/ui-default dev",
    "build": "pnpm -C src build",
    "package": "pnpm -C src dist",
    "test": "pnpm -C src test",
    "test:e2e": "pnpm -C src test:e2e",
    "test:e2e:extensions": "pnpm -C src test:e2e:all",
    "test:e2e:core": "pnpm -C src test:e2e:core",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "create-ext": "node scripts/create-ext.mjs",
    "dev-ext": "node scripts/dev-ext.mjs",
    "doctor": "node scripts/doctor.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "prettier": "^3.8.3",
    "typescript": "^5.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
