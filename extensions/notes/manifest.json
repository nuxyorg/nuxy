{
  "id": "com.nuxy.notes",
  "name": "Notes",
  "version": "1.0.0",
  "type": "tool",
  "providerGroup": "actions",
  "providerGroupLabel": "Tool actions",
  "icon": "notes",
  "permissions": ["storage", "network", "fs", "db"],
  "capabilities": {
    "callable": true,
    "caller": false
  },
  "ipc": {
    "public": ["eval"]
  },
  "entry": {
    "backend": "backend.ts",
    "frontend": "frontend.ts",
    "element": "nuxy-tool-notes",
    "settings": "settings.json"
  },
  "locales": {
    "default": "en",
    "supported": ["en", "tr", "ja"]
  }
}
