{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["../src/node_modules/@types"],
    "paths": {
      "@nuxy/extension-sdk": ["../packages/extension-sdk/src/index.ts"],
      "@nuxy/core": ["../packages/core/src/index.ts"],
      "@nuxy/ui": ["../packages/ui/src/index.tsx"],
      "react-dom": ["../src/node_modules/@types/react-dom"],
      "react-dom/*": ["../src/node_modules/@types/react-dom/*"],
      "vitest": ["../src/node_modules/vitest/dist/index.d.ts"],
      "vitest/*": ["../src/node_modules/vitest/dist/*"],
      "@playwright/test": [
        "../node_modules/.pnpm/@playwright+test@1.60.0/node_modules/@playwright/test/index.d.ts"
      ]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx", "./global.d.ts"],
  "exclude": ["../node_modules", "../src", "../packages"]
}
