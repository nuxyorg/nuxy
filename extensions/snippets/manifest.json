{
  "id": "com.nuxy.snippets",
  "name": "Snippets",
  "version": "1.0.0",
  "type": "tool",
  "icon": "snippet",
  "permissions": ["storage", "clipboard"],
  "capabilities": {
    "callable": true,
    "caller": false
  },
  "entry": {
    "backend": "backend.ts",
    "frontend": "frontend.tsx",
    "settings": "settings.json"
  },
  "locales": {
    "default": "en",
    "supported": ["en", "tr", "ja"]
  }
}
