{
  "version": 1,
  "fields": [
    {
      "key": "downloadPath",
      "label": "Download Location",
      "type": "location",
      "default": "~/Downloads",
      "placeholder": "~/Downloads",
      "description": "Folder where downloaded videos are saved"
    },
    {
      "key": "format",
      "label": "Preferred Format",
      "type": "select",
      "default": "mp4",
      "options": [
        { "value": "mp4", "label": "MP4" },
        { "value": "webm", "label": "WebM" },
        { "value": "mkv", "label": "MKV" },
        { "value": "best", "label": "Best Quality" }
      ]
    },
    {
      "key": "audioOnly",
      "label": "Audio Only",
      "type": "toggle",
      "default": false
    },
    {
      "key": "subtitles",
      "label": "Download Subtitles",
      "type": "toggle",
      "default": false
    }
  ]
}
