{
  "id": "com.nuxy.video-downloader",
  "name": "Video Downloader",
  "version": "1.0.0",
  "type": "tool",
  "providerGroup": "actions",
  "providerGroupLabel": "Tool actions",
  "icon": "video",
  "permissions": ["shell", "fs"],
  "capabilities": {
    "callable": true,
    "caller": true
  },
  "ipc": {
    "public": ["eval", "pause", "resume", "cancel"],
    "samples": {
      "eval": { "text": "https://www.youtube.com/watch?v=abc123" },
      "pause": { "jobId": "job-123" },
      "resume": { "jobId": "job-123" },
      "cancel": { "jobId": "job-123" }
    }
  },
  "behavior": {
    "onComplete": "stay"
  },
  "locales": {
    "default": "en",
    "supported": ["en", "tr", "ja"]
  },
  "entry": {
    "backend": "backend.ts",
    "frontend": "frontend.ts",
    "element": "nuxy-tool-video-downloader",
    "settings": "settings.json"
  }
}
