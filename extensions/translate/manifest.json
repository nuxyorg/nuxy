{
  "id": "com.nuxy.translate",
  "name": "Translate",
  "version": "1.0.0",
  "type": "tool",
  "icon": "translate",
  "description": "Translate text using LibreTranslate.",
  "placeholder": "Type text to translate",
  "permissions": ["network", "clipboard"],
  "capabilities": {
    "callable": false,
    "caller": false
  },
  "locales": {
    "default": "en",
    "supported": ["en", "tr", "ja"]
  },
  "entry": {
    "backend": "backend.ts",
    "frontend": "frontend.tsx",
    "settings": "settings.json"
  }
}
