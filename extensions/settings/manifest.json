{
  "id": "com.nuxy.settings",
  "name": "Settings",
  "version": "1.0.0",
  "type": "tool",
  "icon": "settings",
  "permissions": ["storage", "settings.read", "settings.write"],
  "capabilities": {
    "callable": false,
    "caller": false
  },
  "entry": {
    "backend": "backend.ts",
    "frontend": "frontend.tsx"
  },
  "locales": {
    "default": "en",
    "supported": ["en", "tr", "ja"]
  }
}
