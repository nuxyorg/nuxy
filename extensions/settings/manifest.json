{
  "id": "com.nuxy.settings",
  "name": "Settings",
  "version": "1.0.0",
  "type": "tool",
  "icon": "settings",
  "permissions": ["storage", "settings.read", "settings.write", "extensions.manage"],
  "capabilities": {
    "callable": false,
    "caller": false
  },
  "entry": {
    "backend": "backend.ts",
    "frontend": "frontend.ts",
    "element": "nuxy-tool-settings"
  },
  "locales": {
    "default": "en",
    "supported": ["en", "tr", "ja"]
  },
  "deeplinks": {
    "schemes": ["extension/:extId"]
  }
}
