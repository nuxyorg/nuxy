{
  "id": "com.nuxy.ssh",
  "name": "SSH",
  "version": "1.0.0",
  "type": "tool",
  "permissions": ["shell", "fs"],
  "capabilities": {
    "callable": false,
    "caller": false
  },
  "entry": {
    "backend": "backend.ts",
    "frontend": "frontend.tsx",
    "settings": "settings.json"
  },
  "locales": {
    "default": "en",
    "supported": ["en", "tr"]
  }
}
