      "id": "concept_nuxy_usablekernel",
      "label": "Useless Core Principle (Kernel = Extension Loading + IPC + Window Mgmt only)",
      "file_type": "rationale",
      "source_file": "agents.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "The Core is strictly a Kernel. Its ONLY jobs are Extension Loading, Sandboxed Execution, IPC Routing, and Window Management. If it can be an extension, it MUST be an extension. This is a Gnome-Shell-style architecture."
    },
    {
      "id": "concept_nuxy_zerotrustsecurity",
      "label": "Zero-Trust Default Deny Extension Permissions",
      "file_type": "rationale",
      "source_file": "agents.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Host privileges require permissions in manifest.json. Extensions CANNOT communicate directly \u2014 cross-extension calls use core.extensions.invoke via broker.ts."
    }
