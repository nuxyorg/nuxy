      "id": "concept_nuxy_workerthreadisolation",
      "label": "Worker Thread Isolation for Extension Backends",
      "file_type": "rationale",
      "source_file": "CLAUDE.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Each extension backend runs in its own Worker thread for security and isolation. Calls to core.* send host:call messages to the main thread via parentPort; replies come back as host:reply."
    },
    {
      "id": "concept_nuxy_twolayerui",
      "label": "Two-Layer UI Component System (@nuxy/ui stubs + ui-default runtime)",
      "file_type": "rationale",
      "source_file": "CLAUDE.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "packages/ui provides compile-time stubs delegating to window.UI at runtime; extensions/ui-default provides real custom element implementations. Swapping ui-default changes the entire UI without touching any consumer code."
    },
