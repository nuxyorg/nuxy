    {
      "id": "concept_nuxy_staterefpattern",
      "label": "stateRef Snapshot Pattern for Stable Keyboard Callbacks",
      "file_type": "rationale",
      "source_file": "reports/refactor/refactor_top8_02-06-2026_011131.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Calendar, video-downloader, and settings all use a manually-maintained stateRef.current snapshot to feed stable keyboard callbacks, avoiding stale closures with useToolKeyActions. A shared useStableRef(state) hook is proposed."
    },
    {
      "id": "concept_nuxy_ipcclientpattern",
      "label": "Duplicated ipcCall/invoke Pattern Across Extension Frontends",
      "file_type": "rationale",
      "source_file": "reports/refactor/refactor_top8_02-06-2026_011131.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "All 4 extension frontends (calendar, notes, clipboard, video-downloader) define their own local IPC helper with the same shape. Recommendation: provide a createIpcClient(extId) factory in @nuxy/extension-sdk to unify error handling."
    }
  ],
