{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "publicPackages": ["@nuxyorg/ui"],
  "dynamicallyLoaded": [
    "extensions/**",
    "src/electron/spawn/worker/**",
    "src/electron/bootstrap/main.ts",
    "src/electron/protocol/register.ts"
  ],
  "ignoreDependencies": ["@nuxyorg/extension-host", "@nuxyorg/extension-sdk", "@nuxyorg/ui", "~ext", "lit"],
  "ignorePatterns": [
    "website/**",
    ".claude/**",
    "docs/**",
    "dist/**",
    "dist-electron/**",
    "scratch/**",
    "scratch.js",
    "scratch.cjs",
    "packages/ext-template/**",
    "src/verify-ext-settings.mjs",
    "src/e2e/**"
  ]
}
