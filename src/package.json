{
  "name": "nuxy-desktop",
  "private": true,
  "type": "module",
  "version": "2.0.0",
  "description": "Nuxy desktop launcher",
  "homepage": "https://github.com/nuxy/nuxy",
  "author": "Nuxy",
  "main": "dist-electron/index.js",
  "scripts": {
    "dev": "ELECTRON_OZONE_PLATFORM_HINT=x11 vite",
    "build": "vitest run && vite build",
    "package": "electron-builder --config electron-builder.yml",
    "dist": "pnpm run build && pnpm run package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "dbus-next": "^0.10.2"
  },
  "devDependencies": {
    "@nuxy/core": "workspace:*",
    "@nuxy/extension-host": "workspace:*",
    "@nuxy/ui": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "electron": "^42.1.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^3.0.5",
    "@playwright/test": "^1.51.0"
  }
}
