{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment",
    "strict": true,
    "noUnusedLocals": false,
    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts"]
}
