{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "strict": true,
    "noUnusedLocals": false,
    "types": ["vite/client"],
    "paths": {
      "@nuxyorg/core": ["../../packages/core/src/index.ts"],
      "@nuxyorg/ui": ["../../extensions/ui-default/src/index.ts"],
      "@nuxyorg/extension-sdk": ["../../packages/extension-sdk/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
