{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": false,
    "types": ["vite/client"],
    "paths": {
      "@nuxy/core": ["../../packages/core/src/index.ts"],
      "@nuxy/ui": ["../../extensions/ui-default/src/index.tsx"],
      "@nuxy/extension-sdk": ["../../packages/extension-sdk/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
