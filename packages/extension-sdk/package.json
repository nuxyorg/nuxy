{
  "name": "@nuxyorg/extension-sdk",
  "version": "1.0.1",
  "description": "Authoring API for building Nuxy extensions",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing.ts"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nuxyorg/extension-sdk.git"
  },
  "homepage": "https://github.com/nuxyorg/extension-sdk#readme",
  "bugs": "https://github.com/nuxyorg/extension-sdk/issues",
  "license": "MIT",
  "dependencies": {
    "@nuxyorg/core": "workspace:*"
  },
  "peerDependencies": {
    "vitest": "*"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "*"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./testing": {
        "import": "./dist/testing.js",
        "types": "./dist/testing.d.ts"
      }
    }
  }
}
