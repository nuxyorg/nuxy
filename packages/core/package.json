{
  "name": "@nuxyorg/core",
  "version": "1.0.1",
  "description": "Shared types, IPC message types, and logger for Nuxy extensions",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./lit": "./src/lit.ts",
    "./renderer": "./src/renderer.ts"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nuxyorg/core.git"
  },
  "homepage": "https://github.com/nuxyorg/core#readme",
  "bugs": "https://github.com/nuxyorg/core/issues",
  "license": "MIT",
  "dependencies": {
    "@lit/reactive-element": "^2.1.2",
    "lit": "^3.0.0",
    "lit-html": "^3.3.3"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./lit": {
        "import": "./dist/lit.js",
        "types": "./dist/lit.d.ts"
      },
      "./renderer": {
        "import": "./dist/renderer.js",
        "types": "./dist/renderer.d.ts"
      }
    }
  }
}
